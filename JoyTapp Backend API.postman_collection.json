			"item": [
				{
					"name": "Register",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"  const res = pm.response.json();",
									"  pm.collectionVariables.set('access_token', res.data.tokens.access_token);",
									"  pm.collectionVariables.set('refresh_token', res.data.tokens.refresh_token);",
									"  pm.collectionVariables.set('user_id', res.data.user.id);",
									"  pm.test('Register successful', () => pm.expect(res.success).to.be.true);",
									"  pm.test('Has access token', () => pm.expect(res.data.tokens.access_token).to.be.a('string'));",
									"  pm.test('Has refresh token', () => pm.expect(res.data.tokens.refresh_token).to.be.a('string'));",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"vignesh_dev\",\n  \"email\": \"vignesh@example.com\",\n  \"password\": \"SecurePass123\",\n  \"full_name\": \"Vignesh Selvaraj\"\n}"
						},
