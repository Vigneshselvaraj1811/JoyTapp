# ─── App ────────────────────────────────────────────────
PROJECT_NAME=JoyTapp Backend API
VERSION=1.0.0
API_V1_STR=/api/v1
DEBUG=false
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# ─── MongoDB ─────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=joytapp_db

# ─── JWT ─────────────────────────────────────────────────
# Generate strong secrets: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=c07fcac1091baed73c15d7fc0535736f9c39ecedf58e595a80b5e98c061842775eaef061e9d89e339956493ed97564cf80a05bf350a35250e0b6becf5e804b54
